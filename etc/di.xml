<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <!--
        Each client needs its OWN Curl instance.
        Magento's Curl is a singleton by default, but it accumulates state in
        $_headers and $_curlUserOptions between calls (never reset in makeRequest()).
        If EmbeddingClient and OpenSearch\Client share one Curl object, a previous
        CURLOPT_CUSTOMREQUEST='DELETE'/'PUT' set via setOption() leaks into the next
        POST request, causing the embedding service to receive DELETE instead of POST
        and return an HTML error page instead of JSON embeddings.
    -->


    <!-- Plugin on CatalogSearch collection to rerank results by vector similarity -->
    <type name="Magento\CatalogSearch\Model\ResourceModel\Fulltext\Collection">
        <plugin name="kkkonrad_vector_search_plugin"
                type="Kkkonrad\VectorSearch\Plugin\SearchPlugin"
                sortOrder="10"/>
    </type>

    <!-- Plugin on Search service to substitute search results with hybrid search results early -->
    <type name="Magento\Search\Api\SearchInterface">
        <plugin name="kkkonrad_vector_search_result_plugin"
                type="Kkkonrad\VectorSearch\Plugin\SearchResultPlugin"
                sortOrder="10"/>
    </type>



</config>
